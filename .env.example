BOT_TOKEN=PUT_YOUR_TELEGRAM_BOT_TOKEN_HERE
# Comma-separated list of admin Telegram user IDs
ADMIN_IDS=123456789,987654321

# SQLite file path (relative to project root is OK)
DB_PATH=bot.db

# Telegram parse mode: HTML recommended
PARSE_MODE=HTML

# Optional: delay between questions in seconds (e.g. 0.4)
QUESTION_DELAY_SEC=0.0

# --- BePaid hosted checkout (https://docs.bepaid.by/en/integration/widget/payment_token/) ---
# PUBLIC_BASE_URL — публичный HTTPS URL этого сервиса без завершающего слэша (Railway домен).
# Webhook: {PUBLIC_BASE_URL}/webhooks/bepaid
PUBLIC_BASE_URL=https://YOUR_DOMAIN_HERE

BEPAID_SHOP_ID=YOUR_SHOP_ID
BEPAID_SECRET_KEY=PUT_SECRET_KEY_HERE

# Тестовый режим checkout (true/false)
BEPAID_TEST=true

# Сумма в минимальных единицах валюты (для BYN обычно копейки)
PAYMENT_AMOUNT=1
PAYMENT_CURRENCY=BYN

# HTTP порт для aiohttp (Railway задаёт PORT автоматически)
PORT=8080
